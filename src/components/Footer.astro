---
import CallToAction from './CallToAction.astro'
import { Icon } from 'astro-icon/components'

const currentYear = new Date().getFullYear()

// Social media links with brand colors
const socialLinks = [
  { 
    name: 'YouTube', 
    href: 'https://www.youtube.com/@AaryamanSingh?', 
    icon: 'simple-icons:youtube',
    color: '#FF0000'
  },
  { 
    name: 'X', 
    href: 'https://x.com/Aaryamanz', 
    icon: 'simple-icons:x',
    color: '#111111'
  },
  { 
    name: 'Instagram', 
    href: 'https://www.instagram.com/aaryamanz', 
    icon: 'simple-icons:instagram',
    color: '#E4405F'
  },
  { 
    name: 'LinkedIn', 
    href: 'https://www.linkedin.com/in/aaryamansingh/', 
    icon: 'simple-icons:linkedin',
    color: '#0A66C2'
  },
  { 
    name: 'GitHub', 
    href: 'https://github.com/aaryamanz', 
    icon: 'simple-icons:github',
    color: '#181717'
  }
]
---

<footer class="footer">
  <div class="footer__pattern"></div>
  <div class="footer__gradient"></div>
  <CallToAction />
  
  <div class="footer__inner">
    <div class="footer__main">
      <div class="footer__brand">
        <h3 class="footer__name">Aaryaman Singh</h3>
        <p class="footer__tagline">Precision · Poise · Progress</p>
      </div>

      <div class="footer__socials">
        {socialLinks.map(social => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label={`Follow on ${social.name}`}
            style={`color: ${social.color}`}
          >
            <Icon name={social.icon} class="footer__social-icon" />
          </a>
        ))}
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {currentYear} Aaryaman Singh. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    border-top: 2px solid rgba(147, 51, 234, 0.15);
  }

  .footer__pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.4;
    background-image: radial-gradient(circle at 1px 1px, rgba(147, 51, 234, 0.12) 1px, transparent 0);
    background-size: 20px 20px;
    pointer-events: none;
  }

  .footer__gradient {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
    pointer-events: none;
  }

  .footer__inner {
    position: relative;
    z-index: 1;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0.5rem 0.9rem 0.45rem;
  }

  .footer__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .footer__brand {
    padding-bottom: 0;
  }

  .footer__name {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
    background: none;
    color: #000000;
  }

  .footer__tagline {
    display: none;
    font-size: 0.7rem;
    color: #6b7280;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .footer__sections {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1.5rem;
  }

  @media (min-width: 480px) {
    .footer__sections {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer__heading {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #374151;
    margin: 0 0 0.4rem 0;
  }

  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__list li {
    margin-bottom: 0.2rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: #9333ea;
  }

  .footer__text {
    font-size: 0.95rem;
    color: #4b5563;
  }

  .footer__section--social {
    grid-column: 1 / -1;
  }

  @media (min-width: 480px) {
    .footer__section--social {
      grid-column: auto;
    }
  }

  .footer__socials {
    display: flex;
    gap: 0.5rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: rgba(147, 51, 234, 0.08);
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .footer__social-link:hover {
    background: rgba(147, 51, 234, 0.15);
    transform: translateY(-2px);
  }

  .footer__social-icon {
    width: 13px;
    height: 13px;
  }

  .footer__bottom {
    margin-top: 0.3rem;
    padding-top: 0.3rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: row;
    gap: 0;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .footer__copyright {
    font-size: 0.68rem;
    color: #6b7280;
    margin: 0;
  }

  .footer__legal {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
  }

  .footer__divider {
    color: #d1d5db;
  }

  /* Dark mode */
  :global(.darkmode) .footer {
    border-top-color: rgba(168, 85, 247, 0.2);
  }

  :global(.darkmode) .footer__pattern {
    opacity: 0.2;
    background-image: radial-gradient(circle at 1px 1px, rgba(168, 85, 247, 0.2) 1px, transparent 0);
  }

  :global(.darkmode) .footer__gradient {
    background: linear-gradient(180deg, rgba(20, 20, 28, 0.98) 0%, rgba(15, 15, 20, 1) 100%);
  }

  :global(.darkmode) .footer__tagline,
  :global(.darkmode) .footer__heading {
    color: rgba(255, 255, 255, 0.7);
  }

  :global(.darkmode) .footer__name {
    color: #ffffff;
  }

  :global(.darkmode) .footer__link,
  :global(.darkmode) .footer__text {
    color: rgba(255, 255, 255, 0.8);
  }

  :global(.darkmode) .footer__link:hover {
    color: #c084fc;
  }

  :global(.darkmode) .footer__social-link {
    background: rgba(168, 85, 247, 0.15);
  }

  :global(.darkmode) .footer__social-link:hover {
    background: rgba(168, 85, 247, 0.25);
  }

  :global(.darkmode) .footer__bottom {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  :global(.darkmode) .footer__copyright {
    color: rgba(255, 255, 255, 0.5);
  }

  :global(.darkmode) .footer__divider {
    color: rgba(255, 255, 255, 0.2);
  }
</style>
