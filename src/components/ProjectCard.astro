---
import { Icon } from 'astro-icon/components'

const { 
  icon = 'mdi:rocket',
  title = 'Project Title',
  description = 'Project description',
  href = '/portfolio',
  github,
  tag = 'Tech',
  delay = 0
} = Astro.props
---

<div 
  class="project-card"
  style={`--delay: ${delay}ms`}
>
  <div class="project-card__glow"></div>
  <div class="project-card__inner">
    <span class="project-card__tag">{tag}</span>
    <a href={href} class="project-card__content" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
      <div class="project-card__icon-wrap">
        <Icon name={icon} class="project-card__icon" />
      </div>
      <h3 class="project-card__title">{title}</h3>
      <p class="project-card__desc">{description}</p>
      <span class="project-card__link">
        View Project <span class="project-card__arrow">→</span>
      </span>
    </a>
    {github && (
      <a href={github} class="project-card__github" target="_blank" rel="noopener noreferrer" aria-label={`View ${title} on GitHub`}>
        <Icon name="simple-icons:github" class="project-card__github-icon" /> GitHub
      </a>
    )}
  </div>
</div>

<style>
  .project-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    transform: translateY(20px);
    opacity: 0;
    animation: projectCardFadeIn 0.6s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes projectCardFadeIn {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .project-card__glow {
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, #e000b3 0%, #333399 50%, #007991 100%);
    border-radius: 14px;
    opacity: 0;
    filter: blur(12px);
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .project-card__inner {
    position: relative;
    z-index: 1;
    background: transparent;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.25rem 1rem 2.25rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover .project-card__glow {
    opacity: 0.4;
  }

  .project-card:hover .project-card__inner {
    transform: translateY(-6px);
    border-color: transparent;
    box-shadow: 0 20px 40px -12px rgba(147, 51, 234, 0.25);
  }

  @media (min-width: 768px) {
    .project-card__inner {
      padding: 1.5rem 1.25rem 2.5rem;
    }
  }

  :global(.darkmode) .project-card__inner {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.darkmode) .project-card:hover .project-card__inner {
    border-color: rgba(168, 85, 247, 0.5);
  }

  .project-card__tag {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9333ea;
    background: rgba(147, 51, 234, 0.12);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
  }

  .project-card__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(224, 0, 179, 0.15) 0%, rgba(51, 51, 153, 0.15) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-card__icon-wrap {
    transform: scale(1.1);
  }

  .project-card__icon {
    width: 24px;
    height: 24px;
    color: #9333ea;
  }

  .project-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
    color: #1f2937;
  }

  @media (min-width: 640px) {
    .project-card__title {
      font-size: 1rem;
    }
  }

  :global(.darkmode) .project-card__title {
    color: rgba(255, 255, 255, 0.95);
  }

  .project-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .project-card__desc {
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.5;
    margin: 0 0 1rem 0;
    flex: 1;
  }

  :global(.darkmode) .project-card__desc {
    color: rgba(255, 255, 255, 0.6);
  }

  .project-card__link {
    font-size: 0.8rem;
    font-weight: 600;
    color: #9333ea;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .project-card:hover .project-card__arrow {
    transform: translateX(4px);
  }

  .project-card__arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 0.3s ease;
  }

  .project-card__github {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: #6b7280;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    transition: color 0.3s ease, background 0.3s ease;
    z-index: 2;
  }

  .project-card__github:hover {
    color: #9333ea;
    background: rgba(147, 51, 234, 0.1);
  }

  .project-card__github-icon {
    width: 14px;
    height: 14px;
  }
</style>
