---
import { Icon } from 'astro-icon/components'

const { 
  imgSrc, 
  title, 
  description, 
  github,
  reverseImg = false 
} = Astro.props
---

<section class="portfolio-project">
  <div class="portfolio-project__inner">
    <div class={`portfolio-project__image-wrap ${reverseImg ? 'portfolio-project__image-wrap--reverse' : ''}`}>
      <div class="portfolio-project__image-frame">
        <img 
          src={imgSrc} 
          alt={title}
          class="portfolio-project__image"
          loading="lazy"
        />
      </div>
    </div>
    <div class="portfolio-project__content">
      <h2 class="portfolio-project__title">{title}</h2>
      <div class="portfolio-project__description">
        <slot />
      </div>
      {github && (
        <a 
          href={github} 
          target="_blank" 
          rel="noopener noreferrer"
          class="portfolio-project__link"
        >
          <Icon name="simple-icons:github" class="portfolio-project__link-icon" />
          View on GitHub
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .portfolio-project {
    margin: 3rem 0;
  }

  @media (min-width: 768px) {
    .portfolio-project {
      margin: 4rem 0;
    }
  }

  .portfolio-project__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .portfolio-project__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .portfolio-project__image-wrap--reverse {
      order: 2;
    }

    .portfolio-project__image-wrap--reverse + .portfolio-project__content {
      order: 1;
    }
  }

  .portfolio-project__image-wrap {
    display: flex;
    justify-content: center;
  }

  .portfolio-project__image-frame {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    border: 2px solid rgba(147, 51, 234, 0.15);
    box-shadow: 0 4px 24px -4px rgba(147, 51, 234, 0.12);
    background: linear-gradient(135deg, rgba(224, 0, 179, 0.03) 0%, rgba(51, 51, 153, 0.05) 100%);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .portfolio-project__image-frame:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px -8px rgba(147, 51, 234, 0.2);
  }

  .portfolio-project__image {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .portfolio-project__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .portfolio-project__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
    color: #1f2937;
  }

  @media (min-width: 768px) {
    .portfolio-project__title {
      font-size: 1.4rem;
    }
  }

  :global(.darkmode) .portfolio-project__title {
    color: rgba(255, 255, 255, 0.95);
  }

  .portfolio-project__description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .portfolio-project__description :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .portfolio-project__description :global(p:last-child) {
    margin-bottom: 0;
  }

  :global(.darkmode) .portfolio-project__description {
    color: rgba(255, 255, 255, 0.75);
  }

  .portfolio-project__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #9333ea;
    text-decoration: none;
    border-radius: 10px;
    background: rgba(147, 51, 234, 0.1);
    border: 1px solid rgba(147, 51, 234, 0.25);
    transition: background 0.2s ease, color 0.2s ease;
    width: fit-content;
  }

  .portfolio-project__link:hover {
    background: rgba(147, 51, 234, 0.2);
    color: #7c3aed;
  }

  .portfolio-project__link-icon {
    width: 18px;
    height: 18px;
  }

  :global(.darkmode) .portfolio-project__image-frame {
    border-color: rgba(168, 85, 247, 0.25);
  }

  :global(.darkmode) .portfolio-project__link {
    color: #c084fc;
    background: rgba(168, 85, 247, 0.15);
  }

  :global(.darkmode) .portfolio-project__link:hover {
    background: rgba(168, 85, 247, 0.25);
  }
</style>
