---
import '@astrojs/tailwind/base.css'
import '../assets/scss/globals.scss'
import Analytics from '@vercel/analytics/astro'
import SiteMeta from '../components/SiteMeta.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ShootingStar from '../components/ShootingStar.astro'

const {
  title = 'Aaryaman Singh',
  description = 'My Personal Website',
  url,
  image = '/social-preview-image.png',
  author = 'Aaryaman Singh',
} = Astro.props
---

<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <!-- Theme: run before paint to prevent flash -->
    <script is:inline>
      (function(){
        var t=localStorage.getItem('theme');
        if(t==='light')document.documentElement.classList.remove('darkmode');
        else document.documentElement.classList.add('darkmode');
      })();
    </script>

    <!-- favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <SiteMeta
      title={title}
      description={description.substring(0, 100)}
      url={Astro.site
        ? `${Astro.site}/${title.toLowerCase().replaceAll(' ', '-')}`
        : `https://accessible-astro.dev/${title.toLowerCase().replaceAll(' ', '-')}`}
      image={image}
      author={author}
    />
  </head>
  <body>
    <div id="pointer-glow" aria-hidden="true"></div>
    <ShootingStar />
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <Analytics />
    <script is:inline src="/js/theme.js"></script>
    <script is:inline>
      (function () {
        if (window.__pointerGlowInitialized) return;
        window.__pointerGlowInitialized = true;

        const glow = document.getElementById('pointer-glow');
        if (!glow) return;

        // Skip for touch-only devices.
        if (!window.matchMedia('(pointer: fine)').matches) {
          glow.style.display = 'none';
          return;
        }

        let targetX = window.innerWidth / 2;
        let targetY = window.innerHeight / 2;
        let x = targetX;
        let y = targetY;
        let velocity = 0;
        let rafId = null;
        let visible = false;
        const baseSize = 112;

        const animate = () => {
          const dx = targetX - x;
          const dy = targetY - y;
          x += dx * 0.14;
          y += dy * 0.14;
          velocity = Math.min(1, Math.hypot(dx, dy) / 48);

          const scale = 1 + velocity * 0.12;
          const size = baseSize * scale;
          const alpha = visible ? (0.16 + velocity * 0.06) : 0;
          glow.style.transform = `translate3d(${x - size / 2}px, ${y - size / 2}px, 0) scale(${scale})`;
          glow.style.opacity = String(alpha);

          if (visible || Math.abs(dx) > 0.2 || Math.abs(dy) > 0.2) {
            rafId = requestAnimationFrame(animate);
          } else {
            rafId = null;
          }
        };

        const ensureAnimation = () => {
          if (rafId === null) {
            rafId = requestAnimationFrame(animate);
          }
        };

        window.addEventListener('mousemove', (event) => {
          targetX = event.clientX;
          targetY = event.clientY;
          visible = true;
          ensureAnimation();
        }, { passive: true });

        window.addEventListener('mouseleave', () => {
          visible = false;
          ensureAnimation();
        });
      })();
    </script>
    <script is:inline>
      (function () {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

        const getRevealTargets = () => {
          return document.querySelectorAll(
            'main section, main .skills__card, main .project-card, main .work-item, main .cert-item, main .contact-shell, main .contact-channel'
          );
        };

        if (window.__scrollRevealInitialized) {
          if (typeof window.__refreshScrollReveal === 'function') {
            window.__refreshScrollReveal();
          }
          return;
        }
        window.__scrollRevealInitialized = true;

        const observed = new WeakSet();
        let observer = null;

        const markAllVisible = () => {
          const targets = getRevealTargets();
          targets.forEach((el) => {
            el.classList.add('reveal-on-scroll', 'is-visible');
            el.style.removeProperty('--reveal-delay');
          });
        };

        const ensureObserver = () => {
          if (observer) return observer;
          observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            {
              threshold: 0.12,
              rootMargin: '0px 0px -8% 0px'
            }
          );
          return observer;
        };

        const refreshScrollReveal = () => {
          if (prefersReducedMotion.matches) {
            markAllVisible();
            return;
          }

          const io = ensureObserver();
          const targets = getRevealTargets();
          targets.forEach((el, index) => {
            el.classList.add('reveal-on-scroll');
            if (!el.style.getPropertyValue('--reveal-delay')) {
              el.style.setProperty('--reveal-delay', `${Math.min((index % 8) * 45, 315)}ms`);
            }
            if (!observed.has(el)) {
              observed.add(el);
              io.observe(el);
            }
          });
        };

        window.__refreshScrollReveal = refreshScrollReveal;

        if (typeof prefersReducedMotion.addEventListener === 'function') {
          prefersReducedMotion.addEventListener('change', refreshScrollReveal);
        }

        document.addEventListener('astro:page-load', refreshScrollReveal);
        document.addEventListener('astro:after-swap', refreshScrollReveal);

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', refreshScrollReveal);
        } else {
          refreshScrollReveal();
        }
      })();
    </script>
    <style lang="scss" is:global>
      // theme settings
      :root {
        color-scheme: light;
        --radius-small: 3px;
        --radius-large: 6px;
        --gap-default: 2rem;
        --font-measure: 70ch;
        --font-family-default: 'Open Sans', sans-serif;
        --font-family-special: 'Open Sans', sans-serif;
        // light theme
        --font-color: var(--neutral-900);
        --action-color: var(--primary-300);
        --action-color-state: var(--primary-500);
        --background: var(--neutral-100);
        --primary-background: var(--primary-100);
        --neutral-background: var(--neutral-200);
      }

      // dark color scheme overrides
      html.darkmode {
        color-scheme: dark;
      }
      .darkmode {
        --font-color: var(--neutral-100);
        --action-color: var(--secondary-100);
        --action-color-state: var(--secondary-500);
        --background: #000000;
        --primary-background: var(--primary-500);
        --neutral-background: var(--neutral-900);
      }

      /* Header/nav: white in dark mode */
      html.darkmode header,
      .darkmode header {
        --action-color: rgba(255, 255, 255, 0.95);
        --action-color-state: white;
      }

      // sticky footer on low content pages
      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      html,
      body {
        height: 100%;
      }

      body {
        overflow-x: hidden;
      }

      body {
        display: flex;
        flex-direction: column;
        color: var(--font-color);
        background-color: var(--background);

        main {
          flex: 1 0 auto;
        }

        footer {
          flex-shrink: 0;
        }
      }

      #pointer-glow {
        position: fixed;
        top: 0;
        left: 0;
        width: 112px;
        height: 112px;
        border-radius: 999px;
        pointer-events: none;
        z-index: 9999;
        opacity: 0;
        transform: translate3d(-300px, -300px, 0) scale(1);
        transform-origin: center;
        background: radial-gradient(circle, rgba(15, 23, 42, 0.2) 0%, rgba(51, 65, 85, 0.1) 46%, transparent 74%);
        filter: blur(14px);
        mix-blend-mode: multiply;
        will-change: transform, opacity;
      }

      :global(.darkmode) #pointer-glow,
      :global(html.darkmode) #pointer-glow {
        background: radial-gradient(circle, rgba(186, 141, 255, 0.22) 0%, rgba(154, 123, 208, 0.08) 46%, transparent 74%);
        mix-blend-mode: screen;
      }

      pre {
        padding: 1rem;
        border-radius: 0.35rem;
        border: 2px solid var(--action-color);
      }

      body .pagination a {
        &:hover,
        &:focus-visible {
          background-color: var(--action-color-state);

          svg path {
            stroke: white;
          }
        }
      }

      .reveal-on-scroll {
        opacity: 0;
        transform: translate3d(0, 20px, 0);
        filter: blur(2px);
        transition:
          opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.65s cubic-bezier(0.22, 1, 0.36, 1),
          filter 0.65s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: opacity, transform;
      }

      .reveal-on-scroll.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0);
        filter: blur(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal-on-scroll {
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
