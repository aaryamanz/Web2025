---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import ProjectCard from '../components/ProjectCard.astro'
import AboutSection from '../components/AboutSection.astro'
import ContentMedia2 from '../components/ContentMedia2.astro'
import '/src/assets/css/Skills.css';
---
<DefaultLayout title="Home">
<meta name="google-site-verification" content="WuL6y36yV0_PKG-Q_dyGO5PWHBdEU7FGxY2XpwgXOss" />
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2YP36JNKW1"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-2YP36JNKW1');
</script>
  <Hero />
  <AboutSection />

  <section class="skills pt-8 sm:pt-12 pb-12 sm:pb-16">
      <div class="skills__header max-w-2xl mx-auto">
        <h2 class="text-center text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-3 sm:mb-4">
          <span class="gradient-text">SKILLS</span>
        </h2>
        <p class="skills__subtitle text-center text-sm sm:text-base md:text-lg text-gray-600 leading-relaxed px-2">
          Bridging <span class="highlight">engineering & technology</span> with <span class="highlight">financial analysis</span> — quantitative tools, data-driven insights, and technical problem-solving.
        </p>
      </div>
      <div class="skills__grid">
        <div class="skills__card">
          <h3 class="skills__card-title">Quantitative & Programming</h3>
          <ul class="skills__list-grid">
            <li>Python</li>
            <li>SQL</li>
            <li>MATLAB</li>
            <li>Excel</li>
            <li>R</li>
          </ul>
          <p class="skills__card-desc">Data analysis, backtesting, and quantitative modeling</p>
        </div>
        <div class="skills__card">
          <h3 class="skills__card-title">Financial Analysis</h3>
          <ul class="skills__list-grid">
            <li>Financial Modeling</li>
            <li>Risk Management</li>
            <li>Statistical Analysis</li>
            <li>Power BI</li>
            <li>Portfolio Optimization</li>
          </ul>
          <p class="skills__card-desc">Valuation, risk metrics, and data visualization</p>
        </div>
        <div class="skills__card">
          <h3 class="skills__card-title">Engineering & Design</h3>
          <ul class="skills__list-grid">
            <li>SolidWorks</li>
            <li>AutoCAD</li>
            <li>Ansys</li>
            <li>GitHub</li>
            <li>Data Visualization</li>
          </ul>
          <p class="skills__card-desc">Technical design and systems thinking</p>
        </div>
      </div>
  </section>

  <!-- Projects Section -->
  <section class="projects-section relative">
    <div class="dots-pattern absolute inset-0 z-0 opacity-50"></div>
    <div class="container relative z-10 mx-auto max-w-6xl">
      <div class="projects-section__header text-center mb-8 sm:mb-12">
        <h2 class="text-4xl md:text-5xl lg:text-6xl mb-3">
          <span class="gradient-text">Featured Projects</span>
        </h2>
        <p class="text-gray-600 text-base md:text-lg max-w-2xl mx-auto">
          A mix of quantitative finance, AI, and engineering design
        </p>
      </div>
      <div class="projects-grid">
        <ProjectCard 
          icon="mdi:car-side" 
          title="Autonomous Driving Car"
          description="CNN-based autonomous navigation with OpenCV & YOLOv3 for detection."
          href="/portfolio"
          github="https://github.com/aaryamanz/autonomous-driving"
          tag="AI"
          delay={0}
        />
        <ProjectCard 
          icon="mdi:music" 
          title="Music Genre Classification"
          description="GTZAN dataset analysis with FFT & AlexNet classifier."
          href="/portfolio"
          github="https://github.com/aaryamanz/music-genre-categorization"
          tag="AI"
          delay={50}
        />
        <ProjectCard 
          icon="mdi:chart-line" 
          title="Quantitative Trading"
          description="Moving average & ATR strategy with 50% profit increase."
          href="/portfolio"
          github="https://github.com/aaryamanz/Quantitative-Trading-Strategy-with-Backtesting-and-Risk-Management"
          tag="Finance"
          delay={100}
        />
        <ProjectCard 
          icon="mdi:chart-arc" 
          title="Portfolio Optimization"
          description="MPT optimization, 1.04 Sharpe ratio achievement."
          href="/portfolio"
          github="https://github.com/aaryamanz/Investment-Portfolio-Optimization-Using-Markowitz-Modern-Portfolio-Theory"
          tag="Finance"
          delay={150}
        />
        <ProjectCard 
          icon="mdi:chart-timeline-variant" 
          title="Time-Series Analysis"
          description="GARCH volatility modeling for risk analysis."
          href="/portfolio"
          github="https://github.com/aaryamanz/Anomaly-Detection-and-Risk-Scoring-with-GARCH-Based-Volatility-in-Time-Series-Analysis-for-VFV"
          tag="Finance"
          delay={200}
        />
        <ProjectCard 
          icon="mdi:cog" 
          title="Gearbox Design"
          description="3:1 ratio design with Six Sigma optimization."
          href="/portfolio"
          tag="Engineering"
          delay={250}
        />
      </div>
    </div>
  </section>
{/*
  <ContentMedia imgSrc="/wcag-compliant.webp" reverseImg={true}>
    <h2>WCAG 2.1 AA Compliant</h2>
    <p class="text-2xl">
      Using semantic HTML, landmarks, skip links, screen reader friendly content, aria-labels, keyboard accessible
      navigation and components, clear outlines and tab indicators and the right color contrast, you're more certain of
      reaching WCAG AA compliance.
    </p>
  </ContentMedia>
  <section class="mb-32 mt-64">
    <div class="container">
      <h2 class="mb-16 text-6xl">Counters</h2>
      <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4">
        <Counter count="520" title="Stars" sub="On GitHub" />
        <Counter count="17" title="Accessible" sub="Components" />
        <Counter count="500" title="Commits" sub="Merged" />
        <Counter count="18+" title="Months" sub="Since launch" />
      </div>
    </div>
  </section>
    */}
</DefaultLayout>

<style>
  .projects-section {
    background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(248,250,252,0.95) 100%);
    padding: 2rem 1rem 3rem;
  }

  @media (min-width: 768px) {
    .projects-section {
      padding: 3rem 1.5rem 4rem;
    }
  }

  .projects-section__header {
    padding: 0 0.5rem;
  }

  .projects-section__header h2 {
    font-size: 1.875rem;
  }

  @media (min-width: 640px) {
    .projects-section__header h2 {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .projects-section__header h2 {
      font-size: 3rem;
    }
  }

  .projects-section__header p {
    font-size: 0.875rem;
    padding: 0 0.5rem;
  }

  @media (min-width: 768px) {
    .projects-section__header p {
      font-size: 1rem;
    }
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-10px) scale(1.02);
    }
  }

  :global(.darkmode) .dots-pattern {
    opacity: 0.1;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.3) 1px, transparent 0);
  }

  :global(.darkmode) .projects-section {
    background: linear-gradient(180deg, rgba(15,15,20,0.95) 0%, rgba(20,20,30,0.98) 100%);
  }

  :global(.darkmode) .projects-section__header p {
    color: rgba(255, 255, 255, 0.6);
  }
</style>
