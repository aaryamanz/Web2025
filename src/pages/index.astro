</DefaultLayout>

<style>
  .home-content {
    max-width: 1440px;
  }

  .home-content .about-section {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .home-content .about-section__container,
  .home-content .skills {
    max-width: 100%;
  }

  .home-content .skills {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .projects-container {
    max-width: 100%;
  }

  .home-content .projects-section {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .projects-section {
    background: transparent;
    padding: 2rem 1rem 3rem;
  }

  @media (min-width: 768px) {
    .projects-section {
      padding: 3rem 1.5rem 4rem;
    }
  }

  .projects-section__header {
    padding: 0 0.5rem;
  }

  .projects-section__header h2 {
    font-size: 1.875rem;
  }

  @media (min-width: 640px) {
    .projects-section__header h2 {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .projects-section__header h2 {
      font-size: 3rem;
    }
  }

  .projects-section__header p {
    font-size: 0.875rem;
    padding: 0 0.5rem;
  }

  @media (min-width: 768px) {
    .projects-section__header p {
      font-size: 1rem;
    }
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-10px) scale(1.02);
    }
  }

  :global(.darkmode) .dots-pattern {
    opacity: 0.08;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.25) 1px, transparent 0);
  }

  :global(.darkmode) .projects-section {
    background: transparent;
  }

  :global(.darkmode) .projects-section__header p {
    color: rgba(255, 255, 255, 0.6);
  }
</style>
