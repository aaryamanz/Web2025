---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import ProjectCard from '../components/ProjectCard.astro'
import AboutSection from '../components/AboutSection.astro'
import ContentMedia2 from '../components/ContentMedia2.astro'
import '/src/assets/css/Skills.css';
---
<DefaultLayout title="Home">
<meta name="google-site-verification" content="WuL6y36yV0_PKG-Q_dyGO5PWHBdEU7FGxY2XpwgXOss" />
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2YP36JNKW1"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-2YP36JNKW1');
</script>
  <Hero />
  <div class="home-content container">
  <AboutSection />

  <section class="skills pt-8 sm:pt-12 pb-12 sm:pb-16">
      <div class="skills__header max-w-2xl mx-auto">
        <h2 class="text-center text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-3 sm:mb-4">
          <span class="gradient-text">SKILLS</span>
        </h2>
        <p class="skills__subtitle text-center text-sm sm:text-base md:text-lg text-gray-600 dark:text-gray-300 leading-relaxed px-2">
          <span class="highlight">Capital markets</span> depth, <span class="highlight">strategic analytics</span>, and <span class="highlight">engineering R&D </span>—unified by an entrepreneurial drive to build and optimize.
        </p>
      </div>
      <div class="skills__grid">
        <div class="skills__card">
          <h3 class="skills__card-title">Capital Markets & Quantitative Strategy</h3>
          <ul class="skills__list-grid">
            <li>Python (Pandas, NumPy)</li>
            <li>Financial Modeling</li>
            <li>Derivatives & Options</li>
            <li>Risk Management (VaR)</li>
            <li>Portfolio Optimization</li>
            <li>MATLAB</li>
            <li>Excel (VBA)</li>
          </ul>
          <p class="skills__card-desc">Leveraging statistical methods and algorithmic strategies to uncover market value and optimize capital allocation.</p>
        </div>
        <div class="skills__card">
          <h3 class="skills__card-title">Strategy, Operations & Business Analytics</h3>
          <ul class="skills__list-grid">
            <li>SQL</li>
            <li>Power BI / Tableau</li>
            <li>Data Visualization</li>
            <li>Statistical Analysis</li>
            <li>Process Optimization</li>
            <li>Market Research</li>
            <li>Stakeholder Management</li>
          </ul>
          <p class="skills__card-desc">Translating complex datasets into actionable business insights and streamlined operational strategies.</p>
        </div>
        <div class="skills__card">
          <h3 class="skills__card-title">Engineering R&D & Product Innovation</h3>
          <ul class="skills__list-grid">
            <li>SolidWorks (CAD)</li>
            <li>Ansys (FEA)</li>
            <li>Mechatronics</li>
            <li>Control Systems</li>
            <li>EV Powertrain Design</li>
            <li>AutoCAD</li>
            <li>Rapid Prototyping</li>
          </ul>
          <p class="skills__card-desc">Designing robust physical systems and prototyping scalable hardware solutions from 0 to 1.</p>
        </div>
      </div>
  </section>

  <!-- Projects Section -->
  <section class="projects-section relative">
    <div class="dots-pattern absolute inset-0 z-0 opacity-50"></div>
    <div class="container projects-container relative z-10 mx-auto">
      <div class="projects-section__header text-center mb-8 sm:mb-12">
        <h2 class="text-4xl md:text-5xl lg:text-6xl mb-3">
          <span class="gradient-text">Featured Projects</span>
        </h2>
        <p class="text-gray-600 dark:text-gray-300 text-base md:text-lg max-w-2xl mx-auto">
          A mix of quantitative finance, AI, and engineering design
        </p>
      </div>
      <div class="projects-grid">
        <ProjectCard 
          icon="mdi:chart-line" 
          title="Quantitative Trading"
          description="50% profit increase with MA/ATR strategy. Risk metrics: Sharpe Ratio, Max Drawdown, VaR."
          href="/portfolio"
          github="https://github.com/aaryamanz/Quantitative-Trading-Strategy-with-Backtesting-and-Risk-Management"
          tag="Finance"
          delay={0}
        />
        <ProjectCard 
          icon="mdi:chart-arc" 
          title="Portfolio Optimization"
          description="MPT optimization with Pandas, NumPy & SciPy. 1.04 Sharpe ratio, Efficient Frontier."
          href="/portfolio"
          github="https://github.com/aaryamanz/Investment-Portfolio-Optimization-Using-Markowitz-Modern-Portfolio-Theory"
          tag="Finance"
          delay={50}
        />
        <ProjectCard 
          icon="mdi:chart-timeline-variant" 
          title="Market Volatility Modeling"
          description="GARCH-based volatility and risk scoring for VFV. Industry-specific market analysis."
          href="/portfolio"
          github="https://github.com/aaryamanz/Anomaly-Detection-and-Risk-Scoring-with-GARCH-Based-Volatility-in-Time-Series-Analysis-for-VFV"
          tag="Data & Strategy"
          delay={100}
        />
        <ProjectCard 
          icon="mdi:music" 
          title="Music Genre Classification"
          description="FFT & AlexNet on GTZAN. Translating raw data into classification insights."
          href="/portfolio"
          github="https://github.com/aaryamanz/music-genre-categorization"
          tag="Data & Strategy"
          delay={150}
        />
        <ProjectCard 
          icon="mdi:car-side" 
          title="Autonomous Driving Car"
          description="High-performance system design: CNN navigation, OpenCV & YOLOv3 for real-time detection."
          href="/portfolio"
          github="https://github.com/aaryamanz/autonomous-driving"
          tag="Engineering"
          delay={200}
        />
        <ProjectCard 
          icon="mdi:cog" 
          title="Gearbox Design"
          description="Complex math & physics: 3:1 ratio, Six Sigma optimization. Translates to derivatives pricing rigor."
          href="/portfolio"
          tag="Engineering"
          delay={250}
        />
      </div>
    </div>
  </section>
  </div>
