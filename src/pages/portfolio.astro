---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import PortfolioProject from '../components/PortfolioProject.astro'
import Counter from '../components/Counter.astro'
import '/src/assets/css/styles.css';
---
<DefaultLayout title="Portfolio">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2YP36JNKW1"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-2YP36JNKW1');
</script>

<div class="relative inset-0 block dark:hidden overflow-hidden">
  <div id="particles1" class="fixed inset-0"></div>
  <div id="particles2" class="fixed inset-0"></div>
  <div id="particles3" class="fixed inset-0"></div>
</div>
<div class="relative inset-0 hidden dark:block overflow-hidden">
  <div id="stars1" class="fixed inset-0"></div>
  <div id="stars2" class="fixed inset-0"></div>
  <div id="stars3" class="fixed inset-0"></div>
</div>
<script is:inline src="/js/bg.js"></script>

<div class="portfolio-page">
  <section class="portfolio-hero">
    <div class="portfolio-hero__inner">
      <h1 class="portfolio-hero__title">Portfolio</h1>
      <p class="portfolio-hero__subtitle">Projects spanning financial engineering, AI, and mechanical design</p>
      <div class="portfolio-stats">
        <div class="portfolio-stat">
          <span class="portfolio-stat__number">3</span>
          <span class="portfolio-stat__label">Financial</span>
        </div>
        <div class="portfolio-stat">
          <span class="portfolio-stat__number">2</span>
          <span class="portfolio-stat__label">AI / ML</span>
        </div>
        <div class="portfolio-stat">
          <span class="portfolio-stat__number">4</span>
          <span class="portfolio-stat__label">Engineering</span>
        </div>
        <div class="portfolio-stat">
          <span class="portfolio-stat__number">3</span>
          <span class="portfolio-stat__label">Technical</span>
        </div>
      </div>
    </div>
  </section>

  <div class="portfolio-content">
    <h2 class="portfolio-section-title">Financial Engineering</h2>
    
    <PortfolioProject 
      imgSrc="/portfolio/trading.png" 
      title="Quantitative Trading Strategy with Backtesting and Risk Management"
      github="https://github.com/aaryamanz/Quantitative-Trading-Strategy-with-Backtesting-and-Risk-Management"
      reverseImg={true}
    >
      <p>Developed an algorithmic trading strategy in Python using 50-day and 200-day moving average crossovers combined with an Average True Range (ATR) volatility filter to generate reliable buy/sell signals. Performed comprehensive backtesting on historical stock data to optimize strategy parameters, resulting in a 50% increase in profitability compared to traditional crossover methods.</p>
      <p>Prepared risk management techniques, including position sizing and stop-loss orders, to minimize potential losses and improve the strategy's risk-adjusted returns.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/MPT.png" 
      title="Portfolio Optimization using Modern Portfolio Theory (MPT)"
      github="https://github.com/aaryamanz/Investment-Portfolio-Optimization-Using-Markowitz-Modern-Portfolio-Theory"
      reverseImg={false}
    >
      <p>Developed a Python model for optimizing a tech stock portfolio using Markowitz's Modern Portfolio Theory. Simulated 10,000 portfolios, calculated key financial metrics, and constructed the Efficient Frontier.</p>
      <p>Achieved maximum Sharpe ratio of 1.04 with optimized allocation: 62.47% Google, 23.75% Tesla, and 13.77% Apple.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/vfv.png" 
      title="Anomaly Detection and Risk Scoring with GARCH-Based Volatility for VFV"
      github="https://github.com/aaryamanz/Anomaly-Detection-and-Risk-Scoring-with-GARCH-Based-Volatility-in-Time-Series-Analysis-for-VFV"
      reverseImg={true}
    >
      <p>Robust framework for analyzing risk and detecting anomalies in stock data, applied to the Vanguard S&P 500 Index ETF (VFV). Leveraging GARCH-based volatility modeling to identify high-risk periods and potential fraudulent activity through volatility clusters, kurtosis, and custom risk scores.</p>
    </PortfolioProject>

    <h2 class="portfolio-section-title">Artificial Intelligence</h2>

    <PortfolioProject 
      imgSrc="/portfolio/music1.png" 
      title="Music Genre Categorization: Deep Learning"
      github="https://github.com/aaryamanz/music-genre-categorization"
    >
      <p>Enhanced the GTZAN dataset through data augmentation and conducted detailed analysis of audio signals. Visualized signals in the time domain and examined frequency components using FFT. Utilized AlexNet as a feature extractor on spectrograms, then implemented a fully connected neural network for classification.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/output1.png" 
      title="Autonomous Driving Car with Lane and Object Detection"
      github="https://github.com/aaryamanz/autonomous-driving"
      reverseImg={true}
    >
      <p>CNN based on NVIDIA's model for real-time autonomous navigation in the Udacity simulator. Integrated OpenCV and YOLOv3 for accurate lane detection and object recognition, enhancing decision-making with real-time performance metrics.</p>
    </PortfolioProject>

    <h2 class="portfolio-section-title">Engineering Design</h2>

    <PortfolioProject 
      imgSrc="/portfolio/machine.png" 
      title="Gymbro Dynamics Inc | Improved Lateral Raise Machine"
      reverseImg={true}
    >
      <p>Conducted kinematic, force, and stability analyses to resolve shortcomings. Incorporated advanced linkage systems for enhanced range of motion and degrees of freedom. Introduced independent arm movement, adjustable shoulder width, and optional stabilization. Performed motion analysis using Newton-Raphson methods.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/3dprinter.PNG" 
      title="FDM: 3D Printer"
    >
      <p>Designed an FDM 3D Printer targeting the hobbyist market—maximizing speed and efficiency while minimizing space and cost. With a team of four from UofT, created three candidate designs using SolidWorks, including part analysis and cost design reports.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/gearbox1.PNG" 
      title="Gearbox Design: Rapid-Prototyping"
      reverseImg={true}
    >
      <p>Achieved 3:1 speed reduction in a right-angle gearbox with 90° input/output shafts without worm gears. Utilized SolidWorks with GD&T, pins for assembly, and toolbox gears. Design optimized for 3D printing with fabrication under 6 hours.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/piston1.png" 
      title="Piston: Air Compressed"
    >
      <p>Designed a complete air-compressed piston engine from an aluminium block using isometric drawings. Utilized CNC milling, lathe, and drill press. Optimized center of gravity through design calculations. Completed assembly in under two days.</p>
    </PortfolioProject>

    <h2 class="portfolio-section-title">Technical</h2>

    <PortfolioProject 
      imgSrc="/portfolio/bracelet3.jpg" 
      title="Smart Alerting Bracelet"
      reverseImg={true}
    >
      <p>For St. Lawrence College: designed a bracelet to assist an 8-year-old with ADHD by monitoring volume levels. SolidWorks structure design, Arduino microcontroller for voice detection and alerts. Rapid prototyping and 3D printing achieved a functional classroom-ready device.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/plane1.png" 
      title="Remote-Controlled Aircraft"
    >
      <p>Engineered a high-performance RC Aircraft from lightweight Styrofoam with Brushless Motors, ESC, Servo Motors, and Flysky FS-i6X transmitter (1.5 mile range). Integrated Flaps Landing, Fail Switch, and Auto Landing for enhanced safety and functionality.</p>
    </PortfolioProject>

    <PortfolioProject 
      imgSrc="/portfolio/laser1.jpeg" 
      title="Laser Security System"
      reverseImg={true}
    >
      <p>Developed a Laser Security System for doors using Arduino UNO, breadboard circuits, and IR sensors. Merged circuit design with sensor integration for a responsive security solution.</p>
    </PortfolioProject>
  </div>
</div>
</DefaultLayout>

<style>
  .portfolio-page {
    position: relative;
    z-index: 10;
    padding-bottom: 4rem;
  }

  .portfolio-hero {
    padding: 5rem 1rem 3rem;
  }

  @media (min-width: 768px) {
    .portfolio-hero {
      padding: 6rem 2rem 4rem;
    }
  }

  .portfolio-hero__inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .portfolio-hero__title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    background: linear-gradient(135deg, #e000b3 0%, #333399 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (min-width: 768px) {
    .portfolio-hero__title {
      font-size: 3.5rem;
    }
  }

  .portfolio-hero__subtitle {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 2rem 0;
  }

  @media (min-width: 768px) {
    .portfolio-hero__subtitle {
      font-size: 1.125rem;
    }
  }

  .portfolio-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .portfolio-stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .portfolio-stat {
    padding: 1rem;
    background: white;
    border-radius: 12px;
    border: 2px solid rgba(147, 51, 234, 0.15);
    box-shadow: 0 2px 12px rgba(147, 51, 234, 0.08);
    text-align: center;
    transition: transform 0.2s ease;
  }

  .portfolio-stat:hover {
    transform: translateY(-2px);
  }

  .portfolio-stat__number {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: #9333ea;
    margin-bottom: 0.25rem;
  }

  .portfolio-stat__label {
    font-size: 0.8rem;
    color: #6b7280;
  }

  :global(.darkmode) .portfolio-stat {
    background: rgba(30, 30, 40, 0.9);
    border-color: rgba(168, 85, 247, 0.25);
  }

  :global(.darkmode) .portfolio-stat__label {
    color: rgba(255, 255, 255, 0.6);
  }

  .portfolio-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .portfolio-content {
      padding: 0 2rem;
    }
  }

  .portfolio-section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 4rem 0 1.5rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(147, 51, 234, 0.2);
    background: linear-gradient(135deg, #e000b3 0%, #333399 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .portfolio-section-title:first-of-type {
    margin-top: 0;
  }

  @keyframes animStar {
    from { transform: translateY(0); }
    to { transform: translateY(-2000px); }
  }

  @keyframes animateParticle {
    0% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-500px) translateX(200px); }
    50% { transform: translateY(-1000px) translateX(-200px); }
    75% { transform: translateY(-1500px) translateX(200px); }
    100% { transform: translateY(-2000px) translateX(0); }
  }

  #particles1 { animation: animStar 50s linear infinite; }
  #particles2 { animation: animateParticle 100s linear infinite; }
  #particles3 { animation: animateParticle 150s linear infinite; }
</style>
